# TON Wallet Flow Tracker - example environment.
# Copy to .env and fill in real values. Never commit a real .env.

# --- TON API providers ---
# Get a TonAPI key at https://tonconsole.com and a TON Center key from @tonapibot.
TONAPI_API_KEY=
TONCENTER_API_KEY=
TON_NETWORK=mainnet
TONAPI_BASE_URL=https://tonapi.io
TONCENTER_V3_BASE_URL=https://toncenter.com/api/v3

# --- PostgreSQL ---
POSTGRES_DB=tontracker
POSTGRES_USER=tontracker
POSTGRES_PASSWORD=
# In Docker use host "postgres"; for host-side tooling use "localhost".
# postgresql://USER:PASSWORD@postgres:5432/tontracker
DATABASE_URL=

# --- Application ---
APP_ENV=development
APP_URL=http://localhost:3000
PORT=3000
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=
AUTH_SECRET=
DEMO_MODE=false

# --- Public Telegram links (not secrets; shown in the UI) ---
# Project news channel, and the direct-message link used to request an account.
TELEGRAM_CHANNEL_URL=https://t.me/tonflowapp
TELEGRAM_ACCESS_URL=https://telegram.me/tonflowapp?direct

# --- Analysis limits ---
MEMBER_ANALYSES_PER_WINDOW=10
MEMBER_ANALYSIS_WINDOW_MINUTES=10
MEMBER_MAX_CONCURRENT_ANALYSES=3
MAX_SOURCE_EVENTS=100
MAX_EXPANSION_DEPTH=3
MAX_GRAPH_NODES=150
MAX_GRAPH_EDGES=300

# --- Auth protection ---
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# --- Provider tuning ---
PROVIDER_TIMEOUT_MS=10000
PROVIDER_MAX_RETRIES=3
PROVIDER_CIRCUIT_THRESHOLD=5
PROVIDER_CIRCUIT_RESET_MS=30000
CACHE_TTL_ACCOUNT_MS=30000
CACHE_TTL_EVENTS_MS=60000
CACHE_TTL_DNS_MS=600000
CACHE_TTL_NFT_MS=600000
CACHE_TTL_ERROR_MS=10000
