{
  "name": "ton-wallet-flow-tracker",
  "version": "0.1.0",
  "private": true,
  "description": "Visual analytics for public TON wallet activity.",
  "license": "Apache-2.0",
  "author": "jutsu-dev",
  "homepage": "https://github.com/jutsu-dev/ton-wallet-flow-tracker",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jutsu-dev/ton-wallet-flow-tracker.git"
  },
  "bugs": {
    "url": "https://github.com/jutsu-dev/ton-wallet-flow-tracker/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "prisma generate && next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "audit:prod": "npm audit --omit=dev"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^6.19.3",
    "@tanstack/react-query": "^5.101.2",
    "@xyflow/react": "^12.11.2",
    "clsx": "^2.1.1",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.24.0",
    "next": "^15.5.20",
    "pino": "^10.3.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.7",
    "autoprefixer": "^10.5.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.20",
    "happy-dom": "^20.10.6",
    "msw": "^2.15.0",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.19",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vitest": "^3.2.7"
  }
}
